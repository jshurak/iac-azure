{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "4876585921477438233"
    }
  },
  "parameters": {
    "location": {
      "type": "string"
    },
    "vmCount": {
      "type": "int"
    },
    "prefix": {
      "type": "string"
    },
    "adminName": {
      "type": "string"
    },
    "vmHWType": {
      "type": "string"
    },
    "vmPW": {
      "type": "securestring"
    }
  },
  "resources": [
    {
      "copy": {
        "name": "networkInterface",
        "count": "[length(range(1, parameters('vmCount')))]"
      },
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2020-11-01",
      "name": "[format('{0}-nic-0{1}', parameters('prefix'), range(1, parameters('vmCount'))[copyIndex()])]",
      "location": "[parameters('location')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "name",
            "properties": {
              "privateIPAllocationMethod": "Dynamic",
              "subnet": {
                "id": "[reference(resourceId('Microsoft.Resources/deployments', 'network'), '2025-04-01').outputs.subnetIds.value.vmSubnet]"
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', 'network')]"
      ]
    },
    {
      "copy": {
        "name": "ansibleVMs",
        "count": "[length(range(0, parameters('vmCount')))]"
      },
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2020-12-01",
      "name": "[format('{0}-vm-0{1}', parameters('prefix'), range(0, parameters('vmCount'))[copyIndex()])]",
      "location": "[parameters('location')]",
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('vmHWType')]"
        },
        "osProfile": {
          "computerName": "[format('{0}0{1}', parameters('prefix'), range(0, parameters('vmCount'))[copyIndex()])]",
          "adminUsername": "[parameters('adminName')]",
          "adminPassword": "[parameters('vmPW')]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "Canonical",
            "offer": "ubuntu-26_04-lts",
            "sku": "server",
            "version": "26.04.202604210"
          },
          "osDisk": {
            "name": "[format('{0}-disk-0{1}', parameters('prefix'), range(0, parameters('vmCount'))[copyIndex()])]",
            "caching": "ReadWrite",
            "createOption": "FromImage"
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', format('{0}-nic-0{1}', parameters('prefix'), range(1, parameters('vmCount'))[range(0, parameters('vmCount'))[copyIndex()]]))]"
            }
          ]
        },
        "diagnosticsProfile": {
          "bootDiagnostics": {
            "enabled": false
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', format('{0}-nic-0{1}', parameters('prefix'), range(1, parameters('vmCount'))[range(0, parameters('vmCount'))[copyIndex()]]))]"
      ]
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "network",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.43.8.12551",
              "templateHash": "6632422352550030391"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "defaultValue": "eastus"
            },
            "subnets": {
              "type": "array",
              "defaultValue": [
                "gateway",
                "vm"
              ]
            }
          },
          "variables": {
            "copy": [
              {
                "name": "subnetInfo",
                "count": "[length(parameters('subnets'))]",
                "input": {
                  "name": "[format('{0}Subnet', parameters('subnets')[copyIndex('subnetInfo')])]",
                  "subnetID": "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'js-vnet', format('{0}Subnet', parameters('subnets')[indexOf(parameters('subnets'), parameters('subnets')[copyIndex('subnetInfo')])]))]"
                }
              }
            ]
          },
          "resources": [
            {
              "type": "Microsoft.Network/virtualNetworks",
              "apiVersion": "2019-11-01",
              "name": "js-vnet",
              "location": "[parameters('location')]",
              "properties": {
                "addressSpace": {
                  "addressPrefixes": [
                    "10.2.0.0/16"
                  ]
                }
              }
            },
            {
              "copy": {
                "name": "subnet",
                "count": "[length(parameters('subnets'))]"
              },
              "type": "Microsoft.Network/virtualNetworks/subnets",
              "apiVersion": "2025-05-01",
              "name": "[format('{0}/{1}', 'js-vnet', format('{0}Subnet', parameters('subnets')[copyIndex()]))]",
              "properties": {
                "addressPrefix": "[format('10.2.{0}.0/24', indexOf(parameters('subnets'), parameters('subnets')[copyIndex()]))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Network/virtualNetworks', 'js-vnet')]"
              ]
            }
          ],
          "outputs": {
            "subnetInfo": {
              "type": "array",
              "value": "[variables('subnetInfo')]"
            },
            "subnetIds": {
              "type": "object",
              "value": "[toObject(variables('subnetInfo'), lambda('item', lambdaVariables('item').name), lambda('item', lambdaVariables('item').subnetID))]"
            }
          }
        }
      }
    }
  ]
}