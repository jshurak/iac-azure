{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "1272570861134784190"
    }
  },
  "parameters": {
    "vnetGatewayName": {
      "type": "string",
      "defaultValue": "js-vpn-gw"
    },
    "location": {
      "type": "string",
      "defaultValue": "eastus"
    },
    "gwSharedKey": {
      "type": "string"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2019-11-01",
      "name": "[format('js-gw-pip{0}', uniqueString(resourceGroup().id))]",
      "location": "[parameters('location')]",
      "properties": {
        "publicIPAllocationMethod": "static",
        "dnsSettings": {
          "domainNameLabel": "[format('js-gw-pip{0}', uniqueString(resourceGroup().id))]"
        }
      },
      "sku": {
        "name": "Standard"
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworkGateways",
      "apiVersion": "2025-05-01",
      "name": "[parameters('vnetGatewayName')]",
      "location": "eastus",
      "properties": {
        "enablePrivateIpAddress": false,
        "virtualNetworkGatewayMigrationStatus": {
          "state": "None",
          "phase": "None"
        },
        "ipConfigurations": [
          {
            "name": "default",
            "properties": {
              "privateIPAllocationMethod": "Dynamic",
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', format('js-gw-pip{0}', uniqueString(resourceGroup().id)))]"
              },
              "subnet": {
                "id": "[reference(resourceId('Microsoft.Resources/deployments', 'network'), '2025-04-01').outputs.subnetIds.value.gatewaySubnet]"
              }
            }
          }
        ],
        "natRules": [],
        "virtualNetworkGatewayPolicyGroups": [],
        "enableBgpRouteTranslationForNat": false,
        "disableIPSecReplayProtection": false,
        "sku": {
          "name": "Basic",
          "tier": "Basic"
        },
        "gatewayType": "Vpn",
        "vpnType": "RouteBased",
        "enableBgp": false,
        "enableHighBandwidthVpnGateway": false,
        "activeActive": false,
        "vpnGatewayGeneration": "Generation1",
        "allowRemoteVnetTraffic": false,
        "allowVirtualWanTraffic": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', format('js-gw-pip{0}', uniqueString(resourceGroup().id)))]",
        "[resourceId('Microsoft.Resources/deployments', 'network')]"
      ]
    },
    {
      "type": "Microsoft.Network/localNetworkGateways",
      "apiVersion": "2019-11-01",
      "name": "[format('js-localgw-{0}', uniqueString(resourceGroup().id))]",
      "location": "[parameters('location')]",
      "properties": {
        "localNetworkAddressSpace": {
          "addressPrefixes": [
            "10.10.0.0/16"
          ]
        },
        "gatewayIpAddress": "141.152.229.55"
      }
    },
    {
      "type": "Microsoft.Network/connections",
      "apiVersion": "2020-11-01",
      "name": "udmS2Sconnection",
      "location": "[parameters('location')]",
      "properties": {
        "virtualNetworkGateway1": {
          "id": "[resourceId('Microsoft.Network/virtualNetworkGateways', parameters('vnetGatewayName'))]",
          "properties": {}
        },
        "localNetworkGateway2": {
          "id": "[resourceId('Microsoft.Network/localNetworkGateways', format('js-localgw-{0}', uniqueString(resourceGroup().id)))]",
          "properties": {}
        },
        "connectionType": "IPsec",
        "routingWeight": 0,
        "sharedKey": "[parameters('gwSharedKey')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/localNetworkGateways', format('js-localgw-{0}', uniqueString(resourceGroup().id)))]",
        "[resourceId('Microsoft.Network/virtualNetworkGateways', parameters('vnetGatewayName'))]"
      ]
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "network",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.43.8.12551",
              "templateHash": "6632422352550030391"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "defaultValue": "eastus"
            },
            "subnets": {
              "type": "array",
              "defaultValue": [
                "gateway",
                "vm"
              ]
            }
          },
          "variables": {
            "copy": [
              {
                "name": "subnetInfo",
                "count": "[length(parameters('subnets'))]",
                "input": {
                  "name": "[format('{0}Subnet', parameters('subnets')[copyIndex('subnetInfo')])]",
                  "subnetID": "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'js-vnet', format('{0}Subnet', parameters('subnets')[indexOf(parameters('subnets'), parameters('subnets')[copyIndex('subnetInfo')])]))]"
                }
              }
            ]
          },
          "resources": [
            {
              "type": "Microsoft.Network/virtualNetworks",
              "apiVersion": "2019-11-01",
              "name": "js-vnet",
              "location": "[parameters('location')]",
              "properties": {
                "addressSpace": {
                  "addressPrefixes": [
                    "10.2.0.0/16"
                  ]
                }
              }
            },
            {
              "copy": {
                "name": "subnet",
                "count": "[length(parameters('subnets'))]"
              },
              "type": "Microsoft.Network/virtualNetworks/subnets",
              "apiVersion": "2025-05-01",
              "name": "[format('{0}/{1}', 'js-vnet', format('{0}Subnet', parameters('subnets')[copyIndex()]))]",
              "properties": {
                "addressPrefix": "[format('10.2.{0}.0/24', indexOf(parameters('subnets'), parameters('subnets')[copyIndex()]))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Network/virtualNetworks', 'js-vnet')]"
              ]
            }
          ],
          "outputs": {
            "subnetInfo": {
              "type": "array",
              "value": "[variables('subnetInfo')]"
            },
            "subnetIds": {
              "type": "object",
              "value": "[toObject(variables('subnetInfo'), lambda('item', lambdaVariables('item').name), lambda('item', lambdaVariables('item').subnetID))]"
            }
          }
        }
      }
    }
  ]
}